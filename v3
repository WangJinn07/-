    schedule_text TEXT COMMENT '上课时间描述',
    schedule_type VARCHAR(20) COMMENT '时间类型（工作日/周末）',
    
    district VARCHAR(50) COMMENT '区域',
    address TEXT COMMENT '详细地址',
    
    requirements TEXT COMMENT '详细要求',
    gender_req VARCHAR(10) COMMENT '性别要求',
    
    status VARCHAR(20) DEFAULT 'active' COMMENT '状态（active/closed）',
    view_count INT DEFAULT 0 COMMENT '浏览次数',
    consult_count INT DEFAULT 0 COMMENT '咨询次数',
    
    created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
    updated_at DATETIME DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    
    INDEX idx_demand_no (demand_no),
    INDEX idx_original_no (original_no),
    INDEX idx_district (district),
